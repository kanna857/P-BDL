# Backend Settings
PROJECT_NAME="Entra RBAC Governance System"
API_V1_STR="/api/v1"
SECRET_KEY="replace-this-with-a-very-secure-random-key"
REFRESH_SECRET_KEY="replace-this-with-another-very-secure-random-key"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database Configuration
POSTGRES_SERVER=db
POSTGRES_USER=rbac_admin
POSTGRES_PASSWORD=rbac_secure_password_2026
POSTGRES_DB=rbac_governance_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://rbac_admin:rbac_secure_password_2026@db:5432/rbac_governance_db

# Initial Admin Seeding
SEED_ADMIN_EMAIL=admin@entra-rbac.com
SEED_ADMIN_PASSWORD=AdminPass123!

# Development Settings
ENVIRONMENT=development
BACKEND_CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000", "http://127.0.0.1:5173"]
